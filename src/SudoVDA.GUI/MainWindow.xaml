<Window x:Class="SudoVDA.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        Title="SudoVDA"
        Width="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox x:Name="displayGroup"
                  Grid.Row="0"
                  Header="Display"
                  Margin="0,0,0,12">
            <Grid x:Name="resolutionLayout">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Label x:Name="aspectLabel"
                       Grid.Row="0"
                       Grid.ColumnSpan="4"
                       Content="Aspect ratio"
                       Target="{Binding ElementName=_aspectCombo}" />
                <ComboBox x:Name="_aspectCombo"
                          Grid.Row="1"
                          Grid.ColumnSpan="4"
                          Margin="0,0,0,10"
                          automation:AutomationProperties.AutomationId="aspectCombo"
                          TabIndex="0" />

                <Label x:Name="presetLabel"
                       Grid.Row="2"
                       Grid.ColumnSpan="4"
                       Content="Resolution preset"
                       Target="{Binding ElementName=_presetCombo}" />
                <ComboBox x:Name="_presetCombo"
                          Grid.Row="3"
                          Grid.ColumnSpan="4"
                          Margin="0,0,0,10"
                          automation:AutomationProperties.AutomationId="presetCombo"
                          TabIndex="1" />

                <Label x:Name="widthLabel"
                       Grid.Row="4"
                       Grid.Column="0"
                       Margin="0,0,6,0"
                       Content="Width"
                       Target="{Binding ElementName=_widthText}" />
                <Label x:Name="heightLabel"
                       Grid.Row="4"
                       Grid.Column="1"
                       Margin="6,0"
                       Content="Height"
                       Target="{Binding ElementName=_heightText}" />
                <Label x:Name="refreshLabel"
                       Grid.Row="4"
                       Grid.Column="3"
                       Margin="6,0,0,0"
                       Content="Refresh rate"
                       Target="{Binding ElementName=_refreshCombo}" />

                <TextBox x:Name="_widthText"
                         Grid.Row="5"
                         Grid.Column="0"
                         Margin="0,0,6,0"
                         automation:AutomationProperties.AutomationId="widthText"
                         TabIndex="2" />
                <TextBox x:Name="_heightText"
                         Grid.Row="5"
                         Grid.Column="1"
                         Margin="6,0"
                         automation:AutomationProperties.AutomationId="heightText"
                         TabIndex="3" />
                <ToggleButton x:Name="_aspectLockButton"
                              Grid.Row="5"
                              Grid.Column="2"
                              Margin="6,0"
                              Content="🔓"
                              ToolTip="Lock aspect ratio"
                              automation:AutomationProperties.AutomationId="aspectLockButton"
                              automation:AutomationProperties.Name="Lock aspect ratio"
                              TabIndex="4" />
                <ComboBox x:Name="_refreshCombo"
                          Grid.Row="5"
                          Grid.Column="3"
                          Margin="6,0,0,0"
                          automation:AutomationProperties.AutomationId="refreshCombo"
                          TabIndex="5" />
            </Grid>
        </GroupBox>

        <GroupBox x:Name="behaviorGroup"
                  Grid.Row="1"
                  Header="Behavior">
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="_primaryCheck"
                          Content="Make primary"
                          IsChecked="True"
                          Margin="0,0,24,0"
                          automation:AutomationProperties.AutomationId="primaryCheck"
                          TabIndex="6" />
                <CheckBox x:Name="_routingCheck"
                          Content="Route new windows"
                          IsChecked="True"
                          automation:AutomationProperties.AutomationId="routingCheck"
                          TabIndex="7" />
            </StackPanel>
        </GroupBox>

        <Grid x:Name="footerLayout"
              Grid.Row="3"
              Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="_statusIndicator"
                       Grid.Column="0"
                       Text="●"
                       FontSize="16"
                       Foreground="{DynamicResource ErrorBrush}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       automation:AutomationProperties.AutomationId="statusIndicator" />
            <TextBlock x:Name="_statusLabel"
                       Grid.Column="1"
                       Text="Stopped"
                       Foreground="{DynamicResource MutedForegroundBrush}"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"
                       automation:AutomationProperties.AutomationId="statusLabel" />
            <Button x:Name="_startStopButton"
                    Grid.Column="2"
                    Content="Start"
                    IsDefault="True"
                    automation:AutomationProperties.AutomationId="startStopButton"
                    TabIndex="8" />
        </Grid>
    </Grid>
</Window>
